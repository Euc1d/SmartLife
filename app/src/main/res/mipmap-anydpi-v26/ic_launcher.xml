<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512">
    <defs>
        <linearGradient id="bgGradient" x1="0%" y1="0%" x2="100%" y2="100%">
            <stop offset="0%" style="stop-color:#8B1538;stop-opacity:1" />
            <stop offset="100%" style="stop-color:#FF6B35;stop-opacity:1" />
        </linearGradient>
        <filter id="shadow">
            <feDropShadow dx="0" dy="4" stdDeviation="8" flood-opacity="0.3"/>
        </filter>
    </defs>

    <!-- Фон с градиентом -->
    <rect width="512" height="512" rx="115" fill="url(#bgGradient)"/>

    <!-- Блокнот -->
    <g filter="url(#shadow)">
        <!-- Основная страница -->
        <rect x="140" y="120" width="240" height="300" rx="8" fill="#FFF5E6" opacity="0.95"/>

        <!-- Линии на странице -->
        <line x1="170" y1="180" x2="350" y2="180" stroke="#FF8C42" stroke-width="3" opacity="0.6"/>
        <line x1="170" y1="220" x2="350" y2="220" stroke="#FF8C42" stroke-width="3" opacity="0.6"/>
        <line x1="170" y1="260" x2="320" y2="260" stroke="#FF8C42" stroke-width="3" opacity="0.6"/>
        <line x1="170" y1="300" x2="340" y2="300" stroke="#FF8C42" stroke-width="3" opacity="0.6"/>
        <line x1="170" y1="340" x2="310" y2="340" stroke="#FF8C42" stroke-width="3" opacity="0.6"/>

        <!-- Спираль сверху -->
        <circle cx="170" cy="140" r="8" fill="none" stroke="#6B0F2A" stroke-width="4"/>
        <circle cx="200" cy="140" r="8" fill="none" stroke="#6B0F2A" stroke-width="4"/>
        <circle cx="230" cy="140" r="8" fill="none" stroke="#6B0F2A" stroke-width="4"/>
        <circle cx="260" cy="140" r="8" fill="none" stroke="#6B0F2A" stroke-width="4"/>
        <circle cx="290" cy="140" r="8" fill="none" stroke="#6B0F2A" stroke-width="4"/>
        <circle cx="320" cy="140" r="8" fill="none" stroke="#6B0F2A" stroke-width="4"/>
        <circle cx="350" cy="140" r="8" fill="none" stroke="#6B0F2A" stroke-width="4"/>

        <!-- Карандаш -->
        <g transform="translate(330, 330) rotate(-45)">
            <!-- Корпус карандаша -->
            <rect x="0" y="0" width="80" height="20" rx="2" fill="#FF6B35"/>
            <!-- Наконечник -->
            <polygon points="80,0 100,10 80,20" fill="#FFA500"/>
            <!-- Ластик -->
            <rect x="-15" y="2" width="15" height="16" rx="2" fill="#C41E3A"/>
            <!-- Металлическая часть -->
            <rect x="-3" y="4" width="3" height="12" fill="#8B8B8B"/>
            <!-- Деревянная текстура -->
            <line x1="10" y1="0" x2="10" y2="20" stroke="#E85D2B" stroke-width="1" opacity="0.3"/>
            <line x1="30" y1="0" x2="30" y2="20" stroke="#E85D2B" stroke-width="1" opacity="0.3"/>
            <line x1="50" y1="0" x2="50" y2="20" stroke="#E85D2B" stroke-width="1" opacity="0.3"/>
            <line x1="70" y1="0" x2="70" y2="20" stroke="#E85D2B" stroke-width="1" opacity="0.3"/>
        </g>
    </g>

    <!-- Акцентный угол -->
    <path d="M 512 0 L 512 80 Q 512 0 432 0 Z" fill="#6B0F2A" opacity="0.3"/>
</svg>